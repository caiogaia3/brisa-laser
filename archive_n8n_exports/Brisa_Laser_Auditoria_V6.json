      "id": "webhook-1",
      "name": "Webhook Kommo",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [200, 300]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nlet leadId = null;\n\nif (body['leads[status][0][id]']) {\n  leadId = body['leads[status][0][id]'];\n} else if (body['leads[add][0][id]']) {\n  leadId = body['leads[add][0][id]'];\n}\nif (!leadId && body.leads) {\n  if (body.leads.status && body.leads.status[0]) leadId = body.leads.status[0].id;\n  else if (body.leads.add && body.leads.add[0]) leadId = body.leads.add[0].id;\n}\nif (!leadId) {\n  for (const key of Object.keys(body)) {\n    if (key.includes('[id]') && body[key]) { leadId = body[key]; break; }\n  }\n}\nif (!leadId) throw new Error('Lead ID não encontrado');\n\nreturn [{ json: { leadId: String(leadId) } }];"
      },
