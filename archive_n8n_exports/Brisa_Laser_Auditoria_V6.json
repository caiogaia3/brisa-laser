    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const lead = $input.first().json;\n\n// === PLATAFORMA (Campo 793698) ===\nlet plataforma = 'Não Classificado';\nconst customFields = lead.custom_fields_values || [];\nconst origemField = customFields.find(f => f.field_id === 793698);\nif (origemField) plataforma = origemField.values[0].value;\n\n// === CONTATO (Nome e Telefone) ===\nconst contato = lead._embedded?.contacts?.[0] || {};\nlet nome = contato.name || lead.name || 'Sem Nome';\nlet telefone = '';\n\n// Tentar buscar contato completo via API para pegar telefone\nconst contactId = contato.id;\nif (contactId) {\n  try {\n    const resp = await this.helpers.httpRequest({\n      method: 'GET',\n      url: 'https://brisalaser.kommo.com/api/v4/contacts/' + contactId,\n      headers: { 'Authorization': 'Bearer eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiIsImp0aSI6Ijc3MzliYWExZmVkNTU3ZDIxNGI0ZmQ0YTMwMzQzMjk5ZGIxZjE0MmRmM2FiZWUwZjE5NmY1N2JjNWNhZjdjN2RjMDE5NDliNjRmY2E0YzMxIn0..VbeZU-lBllVqkJ2BkCIdjpnoynvzFzEh1E1zzxFgCxdAWK3gUp8C6rzdlYRKM8MWaIHy79A4iIfSAso-vnYy-0MzzFSAP0v_IbkIQ2xypQnrCn5n1g4XHWWxJr80KnVW1HtkRJO2DqPeLZBkR62V7Cw1-ZQT2N3BiV_0-ejVmDvYeX8NkSkOQOMpayW-YKn_ZgFvnENiSscsKfsBXubV6nJeQqR-ycxZGkNCTwM6MsjmJ-oFxvbCIEBeK0PD8kjrMdX_Di1JVzHOJhbIwfRwc-91Jmu5cd2Rc40RPky8bWaL5hk9ePlzKcMpgQlPYkZeK7KhCrDKYAPxFZDrqPYeqg' },\n      json: true\n    });\n    nome = resp.name || nome;\n    const cFields = resp.custom_fields_values || [];\n    const phoneField = cFields.find(f => f.field_code === 'PHONE');\n    if (phoneField) {\n      let digits = String(phoneField.values[0].value || '').replace(/\\D/g, '');\n      telefone = digits.replace(/^55/, '');\n    }\n  } catch(e) { /* Se falhar, segue sem telefone */ }\n}\n\n// Se nao achou telefone no contato, tenta no lead\nif (!telefone && lead.custom_fields_values) {\n  const leadPhone = lead.custom_fields_values.find(f => f.field_code === 'PHONE');\n  if (leadPhone) {\n    let digits = String(leadPhone.values[0].value || '').replace(/\\D/g, '');\n    telefone = digits.replace(/^55/, '');\n  }\n}\n\nconst hoje = new Date().toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' });\nreturn [{ json: { 'Nome do Cliente': nome, 'Telefone': telefone, 'Plataforma': plataforma, 'Data do Primeiro Contato': hoje } }];"
      },
